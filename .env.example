# ── GitHub ────────────────────────────────────────────────────────────────────
RUNNER_GH_TOKEN=
RUNNER_ORG=NoMercy-Entertainment
RUNNER_GROUP=Default
RUNNER_VERSION=2.322.0

# ── Templates (Proxmox VMIDs) ────────────────────────────────────────────────
RUNNER_TEMPLATE_LINUX=5000
RUNNER_TEMPLATE_MACOS=5001
RUNNER_TEMPLATE_WINDOWS=5002

# ── VM ID range ──────────────────────────────────────────────────────────────
RUNNER_ID_MIN=5100
RUNNER_ID_MAX=5199

# ── Resources per OS ─────────────────────────────────────────────────────────
RUNNER_LINUX_CORES=4
RUNNER_LINUX_MEM=8192
RUNNER_MACOS_CORES=4
RUNNER_MACOS_MEM=8192
RUNNER_WINDOWS_CORES=4
RUNNER_WINDOWS_MEM=8192

# ── Labels per OS ────────────────────────────────────────────────────────────
RUNNER_LINUX_LABELS=self-hosted,Linux,X64,Eagle
RUNNER_MACOS_LABELS=self-hosted,macOS,ARM64,Eagle
RUNNER_WINDOWS_LABELS=self-hosted,Windows,X64,Eagle

# ── ISOs (Linux uses LXC — no image needed) ─────────────────────────────────
RUNNER_MACOS_ISO=nas:iso/macOS-Sequoia-15.iso
RUNNER_WINDOWS_ISO=nas:iso/Win11_25H2_EnglishInternational_x64.iso
