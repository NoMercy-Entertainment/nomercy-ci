# ── GitHub ────────────────────────────────────────────────────────────────────
RUNNER_GH_TOKEN=
RUNNER_ORG=NoMercy-Entertainment
RUNNER_GROUP=Default
RUNNER_VERSION=2.333.0

# ── Templates (Proxmox VMIDs/CTIDs) ─────────────────────────────────────────
RUNNER_TEMPLATE_LINUX=5000
RUNNER_TEMPLATE_MACOS=5001
RUNNER_TEMPLATE_WINDOWS=5002

# ── VM ID range (must not overlap with template IDs above) ───────────────────
RUNNER_ID_MIN=5110
RUNNER_ID_MAX=5199

# ── Resources per OS ─────────────────────────────────────────────────────────
RUNNER_LINUX_CORES=4
RUNNER_LINUX_MEM=8192
RUNNER_MACOS_CORES=4
RUNNER_MACOS_MEM=8192
RUNNER_WINDOWS_CORES=4
RUNNER_WINDOWS_MEM=8192

# ── Labels per OS ────────────────────────────────────────────────────────────
RUNNER_LINUX_LABELS=self-hosted,Linux,X64,Eagle
RUNNER_MACOS_LABELS=self-hosted,macOS,ARM64,Eagle
RUNNER_WINDOWS_LABELS=self-hosted,Windows,X64,Eagle

# ── Pool sizes (ephemeral runner count per OS) ───────────────────────────────
POOL_LINUX=5
POOL_MACOS=1
POOL_WINDOWS=1

# ── Proxmox infrastructure ──────────────────────────────────────────────────
STORAGE=local-lvm
BRIDGE=vmbr0
ISO_STORAGE=nas
VIRTIO_ISO=nas:iso/virtio-win.iso

# ── macOS ────────────────────────────────────────────────────────────────────
RUNNER_OPENCORE_ISO=nas:iso/OpenCore-v21.iso
RUNNER_MACOS_VERSION=sonoma

# ── Windows (uses Win10 autounattend) ────────────────────────────────────────
RUNNER_WINDOWS_ISO=nas:iso/Windows.10.X64.NL.iso
