# NoMercy CI Webhook Server — Environment Configuration
# Copy this file to /opt/nomercy-ci/webhook/webhook_server.env
# and set the values below. DO NOT COMMIT this file to git.

# Required: must match the secret set in GitHub → Settings → Webhooks
GITHUB_SECRET=98d38b22a9af4440ed6d458c45901e1d73c93ecb968aa9136e43705ec75487b7

# Port the webhook server listens on (must be reachable from GitHub)
WEBHOOK_PORT=9000

# Path to the CI scripts directory
CI_ROOT=/opt/nomercy-ci

# Path to artifact/log storage (NFS mount)
ARTIFACT_ROOT=/mnt/vault/nomercy-artifacts
